{
    "name": "aurora/validation",
    "description": "Data validation constraints and validators for Aurora CMS",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {"type": "path", "url": "../typed-data"},
        {"type": "path", "url": "../entity"},
        {"type": "path", "url": "../plugin"},
        {"type": "path", "url": "../cache"},
        {"type": "path", "url": "../config"}
    ],
    "require": {
        "php": ">=8.3",
        "aurora/typed-data": "@dev",
        "aurora/entity": "@dev",
        "symfony/validator": "^7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Aurora\\Validation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aurora\\Validation\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
